{
  "name": "fundhuntr",
  "version": "0.1.0",
  "private": true,
  "description": "Funding, on autopilot. Automatic grant & scholarship applications, worldwide.",
  "scripts": {
    "start": "npx serve . -l 8080",
    "build": "echo 'Static site — no build step. Output is the project root.'",
    "cap:init": "npx cap init FundHuntr com.fundhuntr.app --web-dir=.",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "ios": "npx cap open ios",
    "android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/haptics": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "serve": "^14.2.0"
  },
  "keywords": [
    "scholarships",
    "grants",
    "funding",
    "tinder",
    "pwa",
    "capacitor",
    "mobile-app"
  ],
